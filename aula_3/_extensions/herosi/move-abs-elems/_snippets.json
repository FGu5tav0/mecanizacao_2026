{
  "Absolute image": {
    "prefix": "absolute-image",
    "body": [
      "![](${1:image.png}){.absolute top=${2:10%} left=${3:20%} width=${4:30%}}"
    ],
    "description": "Insert a draggable absolute-positioned image."
  },
  "Absolute div": {
    "prefix": "absolute-div",
    "body": [
      "::: {.absolute top=${1:50%} left=${2:30%}}",
      "${3:Draggable content}",
      ":::"
    ],
    "description": "Insert a draggable absolute-positioned div."
  }
}
